<div class="row m-0">
    @foreach (var tool in Tools)
    {
        <div class="col-4 col-sm-3 col-md-2 col-xl-1 m-0 mt-1 mr-1 p-0" style="min-width:6.5rem;">
            <a href="javascript:;" title="@tool.Name"
                class="text-center list-group-item list-group-item-action border-0 p-0"
                @onclick="()=>Show(tool)">
                <p class="h1 m-0 pt-1"><i class="@tool.IconClass" aria-hidden="true"></i></p>
                <span class="text-center">@tool.Name</span>
            </a>
        </div>
    }
</div>
<ModalWindow @ref="modalWindow" DialogSizeExtraLarge="true" DialogCentered="false" ModalBodyCls="p-0" />