@using System.IO
@using YiQiDong.Protocol.V1.Model

<div class="row">
    <div class="col-12">
        <div class="btn-toolbar">
            <div class="btn-group mr-2 mb-1">
                <div class="btn btn-sm btn-secondary">
                    <i class="fa fa-upload" aria-hidden="true"></i> 上传镜像
                    <input @ref="inputImageFile" id="inputImageFile" type="file" accept=".ymg" style="width: 0px; height: 0px; visibility: collapse;" @onchange="@(e=>onInputImageFileChanged(currenImageId))">
                    <label title="上传镜像" style="position: absolute;top: 0;left: 0;right:0;margin:0;height:100%;cursor:pointer" for="inputImageFile" @onclick="@(e=>currenImageId=null)">
                    </label>
                </div>
                <button type="button" class="btn btn-sm btn-secondary" @onclick="@(()=>ImportImage(null))">
                    <i class="fa fa-reply" aria-hidden="true"></i>
                    导入镜像
                </button>
            </div>          
            <EditForm Model="@this">
                <div class="input-group mr-2 mb-1">
                    <div class="input-group-prepend">
                        <div class="input-group-text">标签</div>
                    </div>
                    <InputSelect class="form-control" @bind-Value="searchTag">
                        <option value="">全部</option>
                        @foreach (var tag in Core.TagManager.Instance.GetTags())
                        {
                            <option value="@tag">@tag</option>
                        }
                    </InputSelect>
                </div>
            </EditForm>
            <div class="input-group mb-1">
                <div class="input-group-prepend">
                    <div class="input-group-text">关键字</div>
                </div>
                <input type="text" class="form-control" @bind-value="searchKeywords">
                <div class="input-group-append">
                    <button type="button" class="btn btn-sm btn-secondary">
                        <i class="fa fa-search"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row">
    @foreach (var t in Core.ImageManager.Instance.Query(searchTag, searchKeywords))
    {
        <div class="col-xl-4 col-lg-6 col-sm-12 mt-2">
            <div class="card">
                <div class="card-header">
                    <i class="fa fa-archive" aria-hidden="true"></i>
                    <span>@t.Name [@t.Version]</span>
                </div>
                <div class="card-body small p-2">
                    @if (t.Tags != null && t.Tags.Length > 0)
                    {
                        <p class="mb-0">
                            <span class="font-weight-bold">标签: </span>
                            @foreach (var tag in t.Tags)
                            {
                                <span class="badge badge-pill badge-light ml-1">@tag</span>
                            }
                        </p>
                    }
                    <p class="mb-0">
                        <span class="font-weight-bold">平台: </span>
                        @foreach (var platform in @t.Platform)
                        {
                            <span class="badge badge-pill badge-light">@platform</span>
                        }
                    </p>
                    @if (t.Runtime != null && t.Runtime.Length > 0)
                    {
                        <p class="mb-0">
                            <span class="font-weight-bold">运行库: </span>
                            @foreach (var runtimeId in t.Runtime)
                            {
                                <span class="badge badge-pill badge-light ml-1">@runtimeId</span>
                            }
                        </p>
                    }
                    @if (!string.IsNullOrEmpty(t.BuildTime))
                    {
                        <p class="mt-1 mb-0"><span class="font-weight-bold">构建时间: </span>@t.BuildTime</p>
                    }
                    <p class="mt-1 mb-0"><span class="font-weight-bold">描述: </span>@t.Description</p>
                </div>
                <div class="card-footer p-1">
                    <div class="btn-group">
                        <button type="button" title="控制台" class="btn btn-sm btn-secondary" @onclick="() => ShowImageConsole(t)">
                            <i class="fa fa-desktop" aria-hidden="true"></i>
                        </button>
                        <button type="button" title="查看文件" class="btn btn-sm btn-secondary" @onclick="@(e => ShowImageFile(t.Id))">
                            <i class="fa fa-folder" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="btn-group">
                        <div class="btn btn-sm btn-secondary">
                            <i class="fa fa-upload" aria-hidden="true"></i>
                            <label title="上传镜像" style="position: absolute;top: 0;left: 0;right:0;margin:0;height:100%;cursor:pointer" for="inputImageFile" @onclick="@(e => currenImageId = t.Id)">
                            </label>
                        </div>
                        <button type="button" title="导入镜像" class="btn btn-sm btn-secondary" @onclick="@(()=>ImportImage(t.Id))">
                            <i class="fa fa-reply" aria-hidden="true"></i>
                        </button>
                        <button type="button" title="打包镜像" class="btn btn-sm btn-secondary" @onclick="@(()=>PackImage(t.Id))">
                            <i class="fa fa-inbox" aria-hidden="true"></i>
                        </button>
                        <button type="button" title="删除" class="btn btn-sm btn-secondary" @onclick="@(e => DeleteImage(t))">
                            <i class="fa fa-trash" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<ModalWindow @ref="modalWindow" DialogSizeExtraLarge="true" DialogCentered="false" ModalBodyCls="p-0" />
<ModalLoading @ref="modalLoading" />
<ModalAlert @ref="modalAlert" />