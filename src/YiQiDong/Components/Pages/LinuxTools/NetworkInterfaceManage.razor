@using System.Net.Sockets
@using System.Net.NetworkInformation

<ToastStack @ref="toastStack" />

<div class="sticky-top">
    <div class="btn-toolbar m-2">
        <div class="btn-group mr-2">
            <button type="button" class="btn btn-sm btn-secondary" @onclick="editNetworkConfigFiles">
                <i class="fa fa-refresh" aria-hidden="true"></i> 编辑网络配置文件
            </button>
        </div>
        <div class="btn-group mr-2">
            <button type="button" class="btn btn-sm btn-secondary" @onclick="restartNetworkService">
                <i class="fa fa-refresh" aria-hidden="true"></i> 重启网络服务
            </button>
        </div>
    </div>
</div>
<ModalLoading @ref="modalLoading" />
<ModalAlert @ref="modalAlert" />
<ModalWindow @ref="modalWindow" DialogSizeExtraLarge="true" DialogCentered="false" />