<div class="row">
    <div class="col-12">
        <div class="btn-toolbar">
            @if (YiQiDong.Cluster.ClusterManager.Instance.Config == null)
            {
                <div class="btn-group mr-2 mb-1">
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="CreateCluster">
                        <i class="fa fa-plus" aria-hidden="true"></i>
                        创建集群
                    </button>
                </div>
            }
            else
            {
                @if (YiQiDong.Cluster.ClusterManager.Instance.Config.AutoStart)
                {
                    <div class="btn-group mr-2 mb-1">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="StopCluster">
                            <i class="fa fa-stop" aria-hidden="true"></i>
                            停止集群
                        </button>
                    </div>
                }
                else
                {
                    <div class="btn-group mr-2 mb-1">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="DeleteCluster">
                            <i class="fa fa-trash" aria-hidden="true"></i>
                            删除集群
                        </button>
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="StartCluster">
                            <i class="fa fa-play" aria-hidden="true"></i>
                            启动集群
                        </button>
                    </div>
                }
            }
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            @if (YiQiDong.Cluster.ClusterManager.Instance.Config != null)
            {
                <div class="card-header pt-1 pb-1">
                    <div class="row">
                        <div>
                            <div class="card text-white bg-info text-center">
                                <div class="card-header">
                                    <i class="fa fa-desktop mr-1"></i>自身节点
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="progress mb-1" style="height:1.5rem;">
                                @if (YiQiDong.Cluster.ClusterManager.Instance.OppositeNodeContext != null && YiQiDong.Cluster.ClusterManager.Instance.OppositeNodeContext.Connected)
                                {
                                    <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                                        <p class="m-0"><i class="fa fa-chevron-right m-1"></i>@YiQiDong.Cluster.ClusterManager.Instance.OppositeNodeContext?.CurrentState</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                                        <p class="m-0"><i class="fa fa-chevron-right m-1"></i>@YiQiDong.Cluster.ClusterManager.Instance.OppositeNodeContext?.CurrentState</p>
                                    </div>
                                }
                            </div>
                            <div class="progress" style="height:1.5rem;">
                                @if (YiQiDong.Cluster.ClusterManager.Instance.OppositeNodeChannel != null)
                                {
                                    <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                                        <p class="m-0"><i class="fa fa-chevron-left m-1"></i>已连接</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                                        <p class="m-0"><i class="fa fa-chevron-left m-1"></i>等待连接...</p>
                                    </div>
                                }
                            </div>
                        </div>
                        <div>
                            <div class="card text-white bg-info text-center">
                                <div class="card-header">
                                    <i class="fa fa-desktop mr-1"></i>对方节点
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <Quick.Blazor.Bootstrap.LogViewControl @ref="clusterLogView" Rows="10"></Quick.Blazor.Bootstrap.LogViewControl>
        </div>
    </div>
    @if (YiQiDong.Cluster.ClusterManager.Instance.Config != null)
    {
        @if (YiQiDong.Cluster.ClusterManager.Instance.IsConnected && !YiQiDong.Cluster.ClusterManager.Instance.Config.AutoStart)
        {
            <div class="col-12">
                <div class="btn-toolbar mt-4">
                    <div class="btn-group mr-2 mb-1">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="AddClusterContainer">
                            <i class="fa fa-plus" aria-hidden="true"></i>
                            添加容器
                        </button>
                    </div>
                </div>
            </div>
        }
        <div class="col-12">
            <table class="table table-sm table-bordered">
                <thead class="thead-light">
                    <tr>
                        <th scope="col">容器</th>
                        <th scope="col">自身节点激活</th>
                        @if (YiQiDong.Cluster.ClusterManager.Instance.IsConnected && !YiQiDong.Cluster.ClusterManager.Instance.Config.AutoStart)
                        {
                            <th scope="col">操作</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in YiQiDong.Cluster.ClusterManager.Instance.Config.ClusterContainerList)
                    {
                        <tr>
                            <td>@item.ContainerName</td>
                            <td>@(item.IsSelfNodeActive?"是":"否")</td>
                            @if (YiQiDong.Cluster.ClusterManager.Instance.IsConnected && !YiQiDong.Cluster.ClusterManager.Instance.Config.AutoStart)
                            {
                                <td>
                                    <a href="javascript:;" @onclick="()=>DeleteClusterContainer(item)">删除</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<ModalWindow @ref="modalWindow" />
<ModalLoading @ref="modalLoading" />
<ModalAlert @ref="modalAlert" />
