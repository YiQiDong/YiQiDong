@using Quick.Fields

<div class="modal-body">
    <form>
        <Quick.Blazor.Bootstrap.QuickFields.Controls @ref="controls" OnFieldChangedAction="OnFieldChanged" ></Quick.Blazor.Bootstrap.QuickFields.Controls>
        @if (controls == null || controls.Fields == null)
        {
            @if (isExecuting)
            {
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="sr-only">加载中...</span>
                    </div>
                </div>
            }
        }
    </form>
</div>
<div>
    <ModalLoading @ref="modalLoading" />
</div>