@using YiQiDong.Components.Layout
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark">
    <base href="./">
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["YiQiDong.styles.css"]" />
    <link href="_content/XtermBlazor/XtermBlazor.min.css" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.ico" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="RenderMode.InteractiveServer" />
    <ReconnectModal />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Quick.Blazor.Bootstrap.Terminal/TerminalControl_Polyfill.js"></script>
    <script src="_content/XtermBlazor/XtermBlazor.min.js"></script>
    <script src="echarts/echarts.min.js"></script>
    <script>
        var exports = exports || {};
    </script>
    <script src="detect-browser/index.js"></script>
    <script>
        setTimeout(function () {
            const browser = detect();
            const el = document.getElementById('loginWindowWarning');
            if (el != null)
                el.innerHTML = '<br/>' + '操作系统: ' + browser.os + '<br/>' + '浏览器: ' + browser.name + ' ' + browser.version + '<br/>提示：如果长时间停留在此界面，可能是浏览器版本太低。请更新浏览器到最新版本后再试。';
        }, 5000);        
    </script>
</body>

</html>
