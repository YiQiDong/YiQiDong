@using YiQiDong.Components.Controls.DevTools
@using static YiQiDong.Components.Controls.CommonToolsControl

<YiQiDong.Components.Controls.CommonToolsControl Tools="@tools" />

@code{
        private ToolInfo[] tools;

        protected override void OnParametersSet()
        {
            base.OnParametersSet();
            tools = new[]
            {
                ToolInfo.Create<RasKeyPairGenerator>("RSA密钥对生成","fa fa-bolt"),
                ToolInfo.Create<GuidGenerator>("GUID生成","fa fa-bolt"),
            };
        }
}