<Accordion AllowMultiplePanelActived="true">
    @foreach (var group in tools.GroupBy(t => t.Category))
    {
        <AccordionPane Key="@group.Key">
            <Tab>@group.Key</Tab>
            <TabCollpsed><i class="fa fa-chevron-right"></i></TabCollpsed>
            <TabExpand><i class="fa fa-chevron-down"></i></TabExpand>
            <ChildContent>
                <div class="row">
                    @foreach (var tool in group)
                    {
                        <div class="col-4 col-sm-3 col-md-2 col-xl-1 m-2" style="min-width:6.5rem;">
                            <a href="javascript:;" title="@tool.Name"
                                class="text-center list-group-item list-group-item-action border-0 p-0"
                                @onclick="() => Show(tool)">
                                <p class="h1 m-0 pt-1"><i class="@tool.IconClass" aria-hidden="true"></i></p>
                                <span class="text-center">@tool.Name</span>
                            </a>
                        </div>
                    }
                </div>
            </ChildContent>
        </AccordionPane>
    }
</Accordion>
<ModalWindow @ref="modalWindow" DialogSizeExtraLarge="true" DialogCentered="false" ModalBodyCls="p-0" />