@using Quick.Blazor.Bootstrap

@inject NavigationManager NavigationManager

<EditForm Model="@config" OnValidSubmit="ModifyConfigModel" class="m-2">
    <DataAnnotationsValidator />
    <div class="form-group pt-1">
        <label>基础目录</label>
        <InputText class="form-control" @bind-Value="config.BaseFolder" />
        <ValidationMessage For="@(() => config.BaseFolder)" />
    </div>
    <div class="form-group">
        <label>密钥</label>
        <InputText class="form-control" @bind-Value="config.Token" />
        <ValidationMessage For="@(() => config.Token)" />
    </div>
    <div class="form-group">
        <label>API地址</label>
        <input type="text" readonly class="form-control" value="@($"{NavigationManager.Uri}Quick.WebFileTransfer")" />
    </div>
    <button type="submit" class="btn btn-primary">
        <i class="fa fa-save" aria-hidden="true"></i>
        保存
    </button>
</EditForm>

<ModalLoading @ref="modalLoading"></ModalLoading>
<ModalAlert @ref="modalAlert"></ModalAlert>